///|
/// Stable request/idempotency key for provider-boundary work.
///
/// The value is pure domain data. It is generated by planning code or a driver,
/// not by transport side effects.
pub struct ProviderRequestId(String) derive(Debug, Eq, Hash, Compare)

///|
pub fn ProviderRequestId::new(value : String) -> ProviderRequestId {
  ProviderRequestId(value)
}

///|
pub fn ProviderRequestId::to_string(self : ProviderRequestId) -> String {
  let ProviderRequestId(value) = self
  value
}

///|
/// Stable identity for the dependency set observed while planning a request.
pub struct ProviderDependencyFingerprint(String) derive(Debug, Eq, Hash, Compare)

///|
pub fn ProviderDependencyFingerprint::new(
  value : String,
) -> ProviderDependencyFingerprint {
  ProviderDependencyFingerprint(value)
}

///|
pub fn ProviderDependencyFingerprint::to_string(
  self : ProviderDependencyFingerprint,
) -> String {
  let ProviderDependencyFingerprint(value) = self
  value
}

///|
/// Safe-to-store identity for provider options after redaction.
///
/// This must not contain secrets, tokens, raw credentials, or unredacted
/// provider-specific configuration.
pub struct RedactedOptionIdentity(String) derive(Debug, Eq, Hash, Compare)

///|
pub fn RedactedOptionIdentity::new(value : String) -> RedactedOptionIdentity {
  RedactedOptionIdentity(value)
}

///|
pub fn RedactedOptionIdentity::to_string(
  self : RedactedOptionIdentity,
) -> String {
  let RedactedOptionIdentity(value) = self
  value
}

///|
/// Provider/model/task provenance that is safe to persist in graph-visible
/// request and result descriptors.
pub(all) struct ProviderOptionProvenance {
  task_kind : String
  provider_id : String
  model_id : String
  option_identity : RedactedOptionIdentity
} derive(Debug, Eq)

///|
pub fn ProviderOptionProvenance::new(
  task_kind~ : String,
  provider_id~ : String,
  model_id~ : String,
  option_identity~ : RedactedOptionIdentity,
) -> ProviderOptionProvenance {
  { task_kind, provider_id, model_id, option_identity }
}

///|
/// Revision observed for one graph source while planning or completing a
/// provider-boundary request.
pub(all) struct ProviderSourceSnapshot {
  key : CognitionKey
  revision : Revision
} derive(Debug, Eq)

///|
pub fn ProviderSourceSnapshot::new(
  key~ : CognitionKey,
  revision~ : Revision,
) -> ProviderSourceSnapshot {
  { key, revision }
}

///|
/// Retry/availability class carried by typed provider errors.
pub(all) enum ProviderRetryClassification {
  RetryableLater(retry_after_ms~ : Int?)
  TerminalUntilConfigurationChanges
  TerminalForRequest
  CallerInitiated
  GraphConsistency
} derive(Debug, Eq)

///|
/// Coarse request-status class for UI/debug state. It intentionally says
/// nothing about drivers, timers, HTTP clients, or async runtimes.
pub(all) enum ProviderStatusClassification {
  NotStarted
  InFlight
  Succeeded
  Failed(ProviderRetryClassification)
} derive(Debug, Eq)

///|
/// Typed, redacted provider-boundary failures.
///
/// Variants describe boundary semantics, not a particular transport library.
/// String payloads must be safe to persist and display.
pub(all) suberror ProviderError {
  Cancelled
  Timeout
  RateLimited(retry_after_ms~ : Int?)
  Auth
  UnsupportedModel(model_id~ : String)
  Network(message~ : String)
  InvalidRequest(message~ : String)
  ProviderRejected(message~ : String)
  Decode(message~ : String)
  BudgetExceeded
  StaleCompletion
} derive(Debug, Eq)

///|
pub fn ProviderError::retry_classification(
  self : ProviderError,
) -> ProviderRetryClassification {
  match self {
    ProviderError::Cancelled => ProviderRetryClassification::CallerInitiated
    ProviderError::Timeout =>
      ProviderRetryClassification::RetryableLater(retry_after_ms=None)
    ProviderError::RateLimited(retry_after_ms~) =>
      ProviderRetryClassification::RetryableLater(retry_after_ms~)
    ProviderError::Auth =>
      ProviderRetryClassification::TerminalUntilConfigurationChanges
    ProviderError::UnsupportedModel(_) =>
      ProviderRetryClassification::TerminalUntilConfigurationChanges
    ProviderError::Network(_) =>
      ProviderRetryClassification::RetryableLater(retry_after_ms=None)
    ProviderError::InvalidRequest(_) =>
      ProviderRetryClassification::TerminalUntilConfigurationChanges
    ProviderError::ProviderRejected(_) =>
      ProviderRetryClassification::TerminalForRequest
    ProviderError::Decode(_) => ProviderRetryClassification::TerminalForRequest
    ProviderError::BudgetExceeded =>
      ProviderRetryClassification::TerminalForRequest
    ProviderError::StaleCompletion =>
      ProviderRetryClassification::GraphConsistency
  }
}

///|
/// Pure request status. This is data only; drivers decide when to execute,
/// cancel, retry, or abandon work.
pub(all) enum ProviderRequestStatus {
  Planned
  Pending
  Succeeded
  Failed(ProviderError)
} derive(Debug, Eq)

///|
pub fn ProviderRequestStatus::classification(
  self : ProviderRequestStatus,
) -> ProviderStatusClassification {
  match self {
    ProviderRequestStatus::Planned => ProviderStatusClassification::NotStarted
    ProviderRequestStatus::Pending => ProviderStatusClassification::InFlight
    ProviderRequestStatus::Succeeded => ProviderStatusClassification::Succeeded
    ProviderRequestStatus::Failed(error) =>
      ProviderStatusClassification::Failed(error.retry_classification())
  }
}

///|
/// Pure provider result payload for an explicit completion record.
pub(all) enum ProviderResult {
  Succeeded(CognitionValue)
  Failed(ProviderError)
} derive(Debug, Eq)

///|
fn ProviderResult::copy_result(self : ProviderResult) -> ProviderResult {
  match self {
    ProviderResult::Succeeded(value) =>
      ProviderResult::Succeeded(value.copy_value())
    ProviderResult::Failed(error) => ProviderResult::Failed(error)
  }
}

///|
/// Planned provider-boundary request descriptor.
///
/// This is the graph-visible contract consumed by an external driver. It does
/// not contain credentials, clients, timers, tasks, or runtime handles.
pub struct ProviderRequestDescriptor {
  priv id : ProviderRequestId
  priv target : CognitionKey
  priv options : ProviderOptionProvenance
  priv context : Array[ContextItem]
  priv source_revisions : Array[ProviderSourceSnapshot]
  priv dependencies : Array[CognitionKey]
  priv dependency_fingerprint : ProviderDependencyFingerprint
} derive(Debug, Eq)

///|
pub fn ProviderRequestDescriptor::new(
  id~ : ProviderRequestId,
  target~ : CognitionKey,
  options~ : ProviderOptionProvenance,
  context~ : Array[ContextItem],
  source_revisions~ : Array[ProviderSourceSnapshot],
  dependencies~ : Array[CognitionKey],
  dependency_fingerprint~ : ProviderDependencyFingerprint,
) -> ProviderRequestDescriptor {
  {
    id,
    target,
    options,
    context: context.copy(),
    source_revisions: source_revisions.copy(),
    dependencies: dependencies.copy(),
    dependency_fingerprint,
  }
}

///|
pub fn ProviderRequestDescriptor::id(
  self : ProviderRequestDescriptor,
) -> ProviderRequestId {
  self.id
}

///|
pub fn ProviderRequestDescriptor::target(
  self : ProviderRequestDescriptor,
) -> CognitionKey {
  self.target
}

///|
pub fn ProviderRequestDescriptor::options(
  self : ProviderRequestDescriptor,
) -> ProviderOptionProvenance {
  self.options
}

///|
pub fn ProviderRequestDescriptor::context(
  self : ProviderRequestDescriptor,
) -> Array[ContextItem] {
  self.context.copy()
}

///|
pub fn ProviderRequestDescriptor::source_revisions(
  self : ProviderRequestDescriptor,
) -> Array[ProviderSourceSnapshot] {
  self.source_revisions.copy()
}

///|
pub fn ProviderRequestDescriptor::dependencies(
  self : ProviderRequestDescriptor,
) -> Array[CognitionKey] {
  self.dependencies.copy()
}

///|
pub fn ProviderRequestDescriptor::dependency_fingerprint(
  self : ProviderRequestDescriptor,
) -> ProviderDependencyFingerprint {
  self.dependency_fingerprint
}

///|
/// Provider result descriptor for an explicit completion attempt.
///
/// Completion validation will compare this data against the planned request;
/// the descriptor itself is ordinary engine-agnostic data.
pub struct ProviderResultDescriptor {
  priv request_id : ProviderRequestId
  priv target : CognitionKey
  priv options : ProviderOptionProvenance
  priv source_revisions : Array[ProviderSourceSnapshot]
  priv dependency_fingerprint : ProviderDependencyFingerprint
  priv result : ProviderResult
} derive(Debug, Eq)

///|
pub fn ProviderResultDescriptor::new(
  request_id~ : ProviderRequestId,
  target~ : CognitionKey,
  options~ : ProviderOptionProvenance,
  source_revisions~ : Array[ProviderSourceSnapshot],
  dependency_fingerprint~ : ProviderDependencyFingerprint,
  result~ : ProviderResult,
) -> ProviderResultDescriptor {
  {
    request_id,
    target,
    options,
    source_revisions: source_revisions.copy(),
    dependency_fingerprint,
    result: result.copy_result(),
  }
}

///|
pub fn ProviderResultDescriptor::request_id(
  self : ProviderResultDescriptor,
) -> ProviderRequestId {
  self.request_id
}

///|
pub fn ProviderResultDescriptor::target(
  self : ProviderResultDescriptor,
) -> CognitionKey {
  self.target
}

///|
pub fn ProviderResultDescriptor::options(
  self : ProviderResultDescriptor,
) -> ProviderOptionProvenance {
  self.options
}

///|
pub fn ProviderResultDescriptor::source_revisions(
  self : ProviderResultDescriptor,
) -> Array[ProviderSourceSnapshot] {
  self.source_revisions.copy()
}

///|
pub fn ProviderResultDescriptor::dependency_fingerprint(
  self : ProviderResultDescriptor,
) -> ProviderDependencyFingerprint {
  self.dependency_fingerprint
}

///|
pub fn ProviderResultDescriptor::result(
  self : ProviderResultDescriptor,
) -> ProviderResult {
  self.result.copy_result()
}

///|
pub fn ProviderResultDescriptor::status(
  self : ProviderResultDescriptor,
) -> ProviderRequestStatus {
  match self.result {
    ProviderResult::Succeeded(_) => ProviderRequestStatus::Succeeded
    ProviderResult::Failed(error) => ProviderRequestStatus::Failed(error)
  }
}

///|
/// Request status descriptor keyed by request id and target.
pub struct ProviderStatusDescriptor {
  priv request_id : ProviderRequestId
  priv target : CognitionKey
  priv status : ProviderRequestStatus
} derive(Debug, Eq)

///|
pub fn ProviderStatusDescriptor::new(
  request_id~ : ProviderRequestId,
  target~ : CognitionKey,
  status~ : ProviderRequestStatus,
) -> ProviderStatusDescriptor {
  { request_id, target, status }
}

///|
pub fn ProviderStatusDescriptor::request_id(
  self : ProviderStatusDescriptor,
) -> ProviderRequestId {
  self.request_id
}

///|
pub fn ProviderStatusDescriptor::target(
  self : ProviderStatusDescriptor,
) -> CognitionKey {
  self.target
}

///|
pub fn ProviderStatusDescriptor::status(
  self : ProviderStatusDescriptor,
) -> ProviderRequestStatus {
  self.status
}

///|
pub fn ProviderStatusDescriptor::classification(
  self : ProviderStatusDescriptor,
) -> ProviderStatusClassification {
  self.status.classification()
}
