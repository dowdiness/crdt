// Canopy public API — import `dowdiness/canopy` for these types.

///|
pub using @editor {
  type SyncEditor,
  type ViewUpdateState,
}

///|
pub using @core {
  type ProjNode,
  type NodeId,
  type SourceMap,
}

///|
pub using @proj {
  type TreeEditorState,
}

///|
pub using @relay {
  type RelayRoom,
}

///|
pub using @protocol {
  type ViewPatch,
  type ViewNode,
}
