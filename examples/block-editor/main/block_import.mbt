///|
/// Import Markdown text into a BlockDoc.
///
/// Line-by-line parser recognising:
/// - `# ` … `###### ` → Heading(n)
/// - `- ` or `* ` → ListItem(Bullet)
/// - `- [ ] ` / `- [x] ` → ListItem(Todo)
/// - `N. ` → ListItem(Numbered)
/// - `> ` → Quote
/// - ` ``` ` … ` ``` ` → Code(lang)
/// - `---` / `***` / `___` → Divider
/// - consecutive non-blank lines → single Paragraph (joined with space)
/// - blank lines → block separator
pub fn block_doc_from_markdown(md : String, replica_id : String) -> BlockDoc {
  let doc = BlockDoc::new(replica_id)
  let lines = split_lines(md)
  let len = lines.length()
  // Accumulator for multi-line paragraphs
  let para_buf : Array[String] = []
  let mut i = 0
  while i < len {
    let line = lines[i]
    // Inside a fenced code block?
    if starts_with(line, "```") {
      // Flush paragraph accumulator
      flush_paragraph(doc, para_buf)
      let lang = string_slice(line, 3, line.length())
      let code_buf = StringBuilder::new()
      i = i + 1
      let mut first = true
      while i < len && not(starts_with(lines[i], "```")) {
        if not(first) {
          code_buf.write_string("\n")
        }
        code_buf.write_string(lines[i])
        first = false
        i = i + 1
      }
      // Skip closing ```
      if i < len {
        i = i + 1
      }
      let id = doc.create_block(Code(lang))
      doc.set_text(id, code_buf.to_string())
      continue
    }
    // Blank line → flush paragraph
    if line == "" {
      flush_paragraph(doc, para_buf)
      i = i + 1
      continue
    }
    // Divider: ---, ***, ___
    if is_divider(line) {
      flush_paragraph(doc, para_buf)
      let _ = doc.create_block(Divider)
      i = i + 1
      continue
    }
    // Heading: # … ######
    let heading_level = count_heading_hashes(line)
    if heading_level > 0 && heading_level <= 6 {
      flush_paragraph(doc, para_buf)
      let text = string_slice(line, heading_level + 1, line.length())
      let id = doc.create_block(Heading(heading_level))
      doc.set_text(id, text)
      i = i + 1
      continue
    }
    // Todo: - [ ] or - [x]
    if starts_with(line, "- [ ] ") {
      flush_paragraph(doc, para_buf)
      let text = string_slice(line, 6, line.length())
      let id = doc.create_block(ListItem(Todo))
      doc.set_text(id, text)
      i = i + 1
      continue
    }
    if starts_with(line, "- [x] ") || starts_with(line, "- [X] ") {
      flush_paragraph(doc, para_buf)
      let text = string_slice(line, 6, line.length())
      let id = doc.create_block(ListItem(Todo))
      doc.set_text(id, text)
      doc.set_checked(id, true)
      i = i + 1
      continue
    }
    // Bullet: - or *
    if starts_with(line, "- ") {
      flush_paragraph(doc, para_buf)
      let text = string_slice(line, 2, line.length())
      let id = doc.create_block(ListItem(Bullet))
      doc.set_text(id, text)
      i = i + 1
      continue
    }
    if starts_with(line, "* ") {
      flush_paragraph(doc, para_buf)
      let text = string_slice(line, 2, line.length())
      let id = doc.create_block(ListItem(Bullet))
      doc.set_text(id, text)
      i = i + 1
      continue
    }
    // Numbered: N.
    let num_prefix = count_numbered_prefix(line)
    if num_prefix > 0 {
      flush_paragraph(doc, para_buf)
      let text = string_slice(line, num_prefix, line.length())
      let id = doc.create_block(ListItem(Numbered))
      doc.set_text(id, text)
      i = i + 1
      continue
    }
    // Quote: >
    if starts_with(line, "> ") {
      flush_paragraph(doc, para_buf)
      let text = string_slice(line, 2, line.length())
      let id = doc.create_block(Quote)
      doc.set_text(id, text)
      i = i + 1
      continue
    }
    // Otherwise: accumulate paragraph
    para_buf.push(line)
    i = i + 1
  }
  // Flush remaining paragraph
  flush_paragraph(doc, para_buf)
  doc
}

// ── Private helpers ────────────────────────────────────────────────────────

///|
fn flush_paragraph(doc : BlockDoc, buf : Array[String]) -> Unit {
  if buf.length() > 0 {
    let text = buf.join(" ")
    let id = doc.create_block(Paragraph)
    doc.set_text(id, text)
    buf.clear()
  }
}

///|
/// Split a string into lines. Handles both \n and \r\n line endings.
/// Drops trailing empty line from trailing newline.
fn split_lines(s : String) -> Array[String] {
  let lines : Array[String] = []
  let buf = StringBuilder::new()
  for i = 0; i < s.length(); i = i + 1 {
    if s[i] == '\r' {
      // Skip \r — if followed by \n, the \n will push the line
      // If \r alone (old Mac), treat as line break
      if i + 1 < s.length() && s[i + 1] == '\n' {
        continue
      } else {
        lines.push(buf.to_string())
        buf.reset()
      }
    } else if s[i] == '\n' {
      lines.push(buf.to_string())
      buf.reset()
    } else {
      buf.write_string(string_slice(s, i, i + 1))
    }
  }
  // If there's remaining content (no trailing newline), add it
  let remaining = buf.to_string()
  if remaining != "" {
    lines.push(remaining)
  }
  lines
}

///|
fn starts_with(s : String, prefix : String) -> Bool {
  if prefix.length() > s.length() {
    return false
  }
  for i = 0; i < prefix.length(); i = i + 1 {
    if s[i] != prefix[i] {
      return false
    }
  }
  true
}

///|
fn string_slice(s : String, start : Int, end : Int) -> String {
  s[start:end].to_string()
}

///|
/// Count leading '#' characters. Returns the heading level if followed by a space,
/// otherwise 0.
fn count_heading_hashes(line : String) -> Int {
  let mut count = 0
  while count < line.length() && line[count] == '#' {
    count = count + 1
  }
  // Must be followed by a space
  if count > 0 && count < line.length() && line[count] == ' ' {
    count
  } else {
    0
  }
}

///|
/// Check if a line is a thematic break: 3+ of the same marker char ('-', '*', '_'),
/// optionally separated by spaces, with nothing else on the line.
fn is_divider(line : String) -> Bool {
  if line.length() < 3 {
    return false
  }
  // Find first non-space character to determine marker
  let mut marker : UInt16 = 0
  for i = 0; i < line.length(); i = i + 1 {
    if line[i] != ' ' {
      marker = line[i]
      break
    }
  }
  if marker != '-' && marker != '*' && marker != '_' {
    return false
  }
  let mut count = 0
  for i = 0; i < line.length(); i = i + 1 {
    if line[i] == marker {
      count = count + 1
    } else if line[i] != ' ' {
      return false
    }
  }
  count >= 3
}

///|
/// If line matches `N. text`, return the offset past "N. " (the length of the prefix).
/// Returns 0 if not a numbered list item.
fn count_numbered_prefix(line : String) -> Int {
  let mut i = 0
  while i < line.length() && line[i] >= '0' && line[i] <= '9' {
    i = i + 1
  }
  // Need at least one digit, then ". "
  if i > 0 && i + 1 < line.length() && line[i] == '.' && line[i + 1] == ' ' {
    i + 2
  } else {
    0
  }
}
