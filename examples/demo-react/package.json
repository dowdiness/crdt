{
  "name": "lambda-crdt-editor-react",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "npm run prebuild:moonbit && concurrently \"npm run server\" \"npm run dev\"",
    "server": "tsx server/ws-server.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prebuild:moonbit": "cd ../.. && moon build --target js",
    "build:all": "npm run prebuild:moonbit && npm run build",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  }
}
