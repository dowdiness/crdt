{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@moonbit/crdt": ["../../_build/js/release/build/ffi/ffi.d.ts"],
      "@moonbit/crdt/moonbit": ["../../_build/js/release/build/ffi/moonbit.d.ts"],
      "@moonbit/crdt-json": ["../../_build/js/release/build/ffi/json/json.d.ts"],
      "@moonbit/crdt-json/moonbit": ["../../_build/js/release/build/ffi/json/moonbit.d.ts"],
      "@moonbit/graphviz": ["../../graphviz/_build/js/release/build/browser/browser.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "../../_build", "../../graphviz/_build"]
}
